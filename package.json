{
  "name": "devops-backend",
  "version": "1.0.0",
  "description": "DevOps Quiz App — JSON-based backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint": "eslint src/backend/ tests/ --ext .js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js", "**/?(*.)+(spec|test).js"],
    "collectCoverageFrom": [
      "src/backend/**/*.js",
      "!src/backend/server.js"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
